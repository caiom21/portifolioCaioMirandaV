---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';
---

<Layout title="Projetos | Caio Miranda" description="Todos os projetos de Caio Miranda — sistemas, bots, apps e interfaces.">

  <!-- Header -->
  <div class="relative w-full border-b border-border">
    <div class="absolute inset-0 bg-grid z-0 pointer-events-none"></div>
    <div class="max-w-[1100px] mx-auto px-6 relative z-10">
      <section class="py-16 md:py-24">
        <h1 class="text-4xl md:text-5xl font-display font-bold leading-tight tracking-tight mb-4 text-text">
          Todos os <span class="text-accent">Projetos</span>
        </h1>
        <p class="text-sm font-mono text-text-secondary max-w-md leading-relaxed">
          Lista completa de sistemas, bots e interfaces.
        </p>
      </section>
    </div>
  </div>

  <!-- Projects grid -->
  <section class="max-w-[1100px] mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 gap-4">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <Footer />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener('astro:page-load', () => {
      gsap.registerPlugin(ScrollTrigger);

      const elements = document.querySelectorAll('.reveal');
      elements.forEach((el) => {
        gsap.fromTo(el, { opacity: 0, y: 20 }, {
          scrollTrigger: { trigger: el, start: "top 95%" },
          y: 0, opacity: 1, duration: 0.8, ease: "power2.out", clearProps: "all"
        });
      });
    });
  </script>
</Layout>
