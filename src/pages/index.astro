---
import Layout from '../layouts/Layout.astro';

const projetos = [
  {
    type: 'BOT . PYTHON',
    title: 'Bot Trader',
    description: '17 versoes de estrategias quantitativas. Deploy containerizado, paper trading 24/7 na Kraken.',
    tags: ['PYTHON', 'FREQTRADE', 'DOCKER', 'TA-LIB'],
    repo: 'https://github.com/caiom21/bot-trader'
  },
  {
    type: 'WEB . REACT',
    title: 'Ponto Cruz E-commerce',
    description: 'Loja de artesanatos e bordados com foco em performance e acessibilidade.',
    tags: ['REACT', 'NODE.JS', 'TAILWIND'],
    repo: 'https://github.com/caiom21/ponto-cruz-ecommerce'
  }
];

const stack = [
  'REACT', 'TYPESCRIPT', 'NODE.JS', 'NEXT.JS',
  'VUE.JS', 'PYTHON', 'DOCKER', 'FIGMA',
  'N8N', 'POSTGRESQL', 'TAILWIND', 'REACT NATIVE',
];

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/caiom21', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.36 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.36 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/caio-miranda-246603374', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>' },
  { name: 'Instagram', href: 'https://www.instagram.com/caio.dev.pe/', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>' },
];

const experiencia = [
  {
    role: 'Consultor Tecnico de Vendas',
    company: 'OS Sistemas',
    period: 'Out 2024 - Presente',
    tags: ['SUPORTE TECNICO', 'LEVANTAMENTO DE REQUISITOS', 'GESTAO DE EQUIPE', 'SLA'],
    desc: 'Suporte tecnico a clientes, levantamento de requisitos para correcoes e melhorias na plataforma de gestao escolar. Acompanhamento de metricas com ferramentas como Hotjar e Google Analytics. Assistencia na gestao de equipe e treinamentos.'
  },
  {
    role: 'Gerente',
    company: 'Otica Fatima',
    period: '2022 - 2024',
    tags: ['GESTAO COMERCIAL', 'VENDAS B2B', 'RELACIONAMENTO'],
    desc: 'Gestao comercial, estrategias de vendas, fortalecimento de relacionamento com fornecedores e clientes B2B.'
  }
];

const formacao = [
  {
    title: 'Ciencia da Computacao',
    school: 'UNICA',
    period: '6o Periodo',
    icon: '🎓'
  },
  {
    title: 'Tecnico em Informatica',
    school: 'EBTTA',
    period: 'Concluido',
    icon: '📋'
  },
  {
    title: 'Engenharia de Front-end',
    school: 'Origamid',
    period: 'Certificacao',
    icon: '⚛️'
  },
  {
    title: 'UI/UX Design',
    school: 'Origamid',
    period: 'Certificacao',
    icon: '🎨'
  }
];

const stats = [
  { value: '2+', label: 'Anos de Experiencia' },
  { value: '15+', label: 'Projetos Concluidos' },
  { value: '12+', label: 'Tecnologias' },
  { value: '6o', label: 'Periodo Ci. Computacao' },
];
---

<Layout title="Caio Miranda | Desenvolvedor de Software">

  <!-- ====== HERO ====== -->
  <section class="relative w-full min-h-[100vh] flex items-center">
    <div class="absolute inset-0 bg-grid z-0 pointer-events-none"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-[1fr_auto] gap-12 items-center">

        <div class="max-w-3xl">
          <!-- Terminal intro -->
          <div class="mb-8 inline-block font-mono text-xs leading-relaxed hero-terminal">
            <span class="text-accent">&gt;</span> <span class="text-text/60">iniciar apresentacao()</span><br/>
            <span class="text-accent">&gt;</span> <span class="text-text typing-line" id="typewriter"></span><span class="animate-blink inline-block w-2 h-4 bg-accent align-middle ml-0.5" id="cursor-blink"></span>
          </div>

          <h1 class="text-5xl sm:text-6xl md:text-8xl font-sans font-bold leading-[0.9] tracking-tight text-text hero-name">
            Caio<br/><span class="text-accent">Miranda</span>
          </h1>

          <p class="mt-6 text-sm font-mono text-text/60 leading-relaxed max-w-xl hero-desc">
            Desenvolvedor de Software com foco em desenvolvimento web full-stack, automacao, integracao de sistemas e inteligencia artificial. Ciencia da Computacao, 6o periodo.
          </p>

          <!-- Contact pills -->
          <div class="flex flex-wrap gap-3 mt-6 hero-contact">
            <a href="mailto:caiom2a@gmail.com" class="inline-flex items-center gap-2 px-3 py-1.5 border border-accent/30 text-[11px] font-mono text-accent hover:bg-accent/10 transition-colors rounded">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              caiom2a@gmail.com
            </a>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 border border-text/15 text-[11px] font-mono text-text/50 rounded">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +55 87 9 8811-9519
            </span>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 border border-text/15 text-[11px] font-mono text-text/50 rounded">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Bezerros, PE
            </span>
          </div>

          <!-- Social + CTAs -->
          <div class="flex flex-col sm:flex-row items-start gap-6 mt-10 hero-actions">
            <div class="flex gap-3">
              {socialLinks.map(social => (
                <a href={social.href} target="_blank" rel="noopener noreferrer"
                   class="w-10 h-10 flex items-center justify-center border border-text/20 text-text/50 hover:border-accent hover:text-accent transition-all hover:scale-110"
                   aria-label={social.name}
                   set:html={social.svg} />
              ))}
            </div>
            <div class="flex gap-3">
              <a href="#projetos" class="px-6 py-3 border border-accent text-accent hover:bg-accent hover:text-bg transition-colors font-mono text-sm uppercase">Ver Projetos</a>
              <a href="/contato" class="px-6 py-3 border border-text/20 text-text/80 hover:border-text hover:text-text transition-colors font-mono text-sm uppercase">Contato</a>
            </div>
          </div>
        </div>

        <!-- Photo -->
        <div class="hidden md:flex-shrink-0">
          <div class="w-72 h-72 relative group border border-accent/20 hover:border-accent transition-colors overflow-hidden">
            <div class="card-corner z-20"></div>
            <img src="/fotoPerfil.jpg" alt="Caio Miranda" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 z-10 relative" loading="eager" />
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 scroll-indicator opacity-0">
      <span class="text-[10px] font-mono tracking-widest text-text/30 uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-accent/60 to-transparent"></div>
    </div>
  </section>

  <!-- ====== STATS ====== -->
  <section class="border-y border-accent/20 bg-surface">
    <div class="container mx-auto px-4 py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 stats-grid">
        {stats.map(stat => (
          <div class="text-center reveal">
            <div class="text-3xl md:text-4xl font-bold text-accent stat-value" data-value={stat.value}>{stat.value}</div>
            <div class="text-[11px] font-mono tracking-widest text-text/40 mt-2 uppercase">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== SOBRE ====== -->
  <section class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="grid md:grid-cols-[auto_1fr] gap-16 items-start">
      <div class="hidden md:block">
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2 sticky top-24">Sobre</h2>
      </div>
      <div class="reveal">
        <p class="text-base font-mono text-text/70 leading-relaxed max-w-3xl">
          Desenvolvedor de Software com experiencia em projetos que combinam eficiencia, comunicacao e inteligencia artificial. Atuante em suporte tecnico, levantamento de requisitos, gestao de equipe e acompanhamento de metricas. Sempre priorizando resultados mensuraveis e impacto nos negocios.
        </p>
        <div class="flex flex-wrap gap-2 mt-8">
          {stack.map(tech => (
            <span class="px-3 py-1.5 border border-accent/20 bg-accent/5 text-[10px] font-mono tracking-wider text-text/50 hover:text-accent hover:border-accent transition-all reveal">{tech}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====== EXPERIENCIA ====== -->
  <section class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="grid md:grid-cols-[auto_1fr] gap-16 items-start">
      <div class="hidden md:block">
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2 sticky top-24">Experiencia</h2>
      </div>
      <div class="space-y-0">
        {experiencia.map((exp, i) => (
          <div class={`reveal relative border-l-2 border-accent/20 pl-8 pb-12 last:pb-0 ${i === 0 ? '' : 'mt-4'}`}>
            <div class="absolute -left-[5px] top-0 w-2.5 h-2.5 rounded-full bg-accent timeline-dot"></div>
            <div class="bg-surface border border-accent/10 p-8 group hover:border-accent/40 transition-colors">
              <div class="flex flex-wrap items-center justify-between gap-2 mb-1">
                <h3 class="text-lg font-bold text-text">{exp.role}</h3>
                <span class="text-[10px] font-mono tracking-wider text-accent bg-accent/10 px-2 py-0.5">{exp.period}</span>
              </div>
              <p class="text-xs font-mono text-text/50 mb-4">{exp.company}</p>
              <p class="text-sm font-mono text-text/60 leading-relaxed mb-4">{exp.desc}</p>
              <div class="flex flex-wrap gap-2">
                {exp.tags.map(tag => (
                  <span class="px-2 py-0.5 border border-accent/20 text-accent text-[9px] font-mono tracking-wider">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FORMACAO ====== -->
  <section class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="grid md:grid-cols-[auto_1fr] gap-16 items-start">
      <div class="hidden md:block">
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2 sticky top-24">Formacao</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {formacao.map(f => (
          <div class="border border-accent/15 bg-surface p-6 group hover:border-accent/40 transition-all reveal">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="text-sm font-bold text-text mb-1">{f.title}</h3>
            <p class="text-[11px] font-mono text-text/50">{f.school} · {f.period}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== PROJETOS ====== -->
  <section id="projetos" class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2">Projetos em destaque</h2>
        <p class="text-sm font-mono text-text/40">Trabalhos recentes e relevantes.</p>
      </div>
      <a href="/projetos" class="hidden md:block text-xs font-mono tracking-widest text-accent/60 hover:text-accent transition-colors">Ver todos &rarr;</a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {projetos.map(proj => (
        <a href={proj.repo} target="_blank" class="relative bg-surface border border-accent/20 p-8 group hover:border-accent transition-colors reveal block">
          <div class="card-corner opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="text-[10px] font-mono tracking-widest text-text/40 mb-3 uppercase">{proj.type}</div>
          <h3 class="text-xl font-bold mb-3 text-text">{proj.title}</h3>
          <p class="text-sm font-mono text-text/60 mb-6">{proj.description}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {proj.tags.map(tag => (
              <span class="px-2 py-1 border border-accent/30 text-accent text-[10px] font-mono tracking-wider">{tag}</span>
            ))}
          </div>
          <span class="text-xs font-mono tracking-widest text-accent/50 group-hover:text-accent transition-colors">CODIGO-FONTE &rarr;</span>
        </a>
      ))}
    </div>
    <div class="md:hidden mt-6 text-center">
      <a href="/projetos" class="text-xs font-mono tracking-widest text-accent/60 hover:text-accent transition-colors">Ver todos os projetos &rarr;</a>
    </div>
  </section>

  <!-- ====== FOOTER ====== -->
  <footer class="container mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-left">
        <p class="text-xs font-mono text-text/40">&copy; 2026 Caio Miranda. Todos os direitos reservados.</p>
      </div>
      <div class="flex items-center gap-4">
        {socialLinks.map(social => (
          <a href={social.href} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 flex items-center justify-center text-text/30 hover:text-accent transition-colors"
             aria-label={social.name}
             set:html={social.svg} />
        ))}
      </div>
    </div>
  </footer>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener('astro:page-load', () => {
      gsap.registerPlugin(ScrollTrigger);

      // Typewriter effect
      const text = 'Caio Miranda, desenvolvedor full-stack.';
      const el = document.getElementById('typewriter');
      const cursor = document.getElementById('cursor-blink');
      let i = 0;
      function type() {
        if (i < text.length) {
          el.textContent += text.charAt(i);
          i++;
          setTimeout(type, 40 + Math.random() * 40);
        } else {
          // Remove cursor blink after typing done
          setTimeout(() => {
            if (cursor) cursor.style.animation = 'none';
          }, 2000);
        }
      }
      setTimeout(type, 800);
      if (cursor) {
        const sheet = document.styleSheets[0];
        sheet.insertRule(`@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}`, 0);
        cursor.style.animation = 'blink 0.7s step-end infinite';
      }

      // Hero entrance
      gsap.fromTo('.hero-name', { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: "power3.out", delay: 0.1 });
      gsap.fromTo('.hero-terminal', { opacity: 0, x: -20 }, { opacity: 1, x: 0, duration: 0.6, ease: "power2.out" });

      const contactEls = document.querySelectorAll('.hero-contact');
      if (contactEls.length) {
        gsap.fromTo(contactEls, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out", delay: 1.8 });
      }

      gsap.fromTo('.hero-actions',
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: "power2.out", delay: 2 }
      );

      gsap.fromTo('.hero-desc',
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", delay: 1.5 }
      );

      // Scroll indicator
      gsap.to('.scroll-indicator', { opacity: 1, duration: 0.5, delay: 2.5 });
      gsap.to('.scroll-indicator > div', { height: 0, opacity: 0, duration: 1.5, repeat: -1, yoyo: true, ease: "power1.inOut" });

      // Photo entrance
      gsap.fromTo('.hero-photo', { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 1, ease: "power2.out", delay: 0.3 });

      // Reveal on scroll
      const elements = document.querySelectorAll('.reveal');
      elements.forEach((el) => {
        gsap.fromTo(el, { opacity: 0, y: 30 }, {
          scrollTrigger: { trigger: el, start: "top 90%" },
          y: 0, opacity: 1, duration: 0.8, ease: "power2.out", clearProps: "all"
        });
      });

      // Timeline dots
      gsap.fromTo('.timeline-dot', { scale: 0 }, { scale: 1, duration: 0.4, ease: "back.out(2)", stagger: 0.2, scrollTrigger: { trigger: '.timeline-dot', start: "top 85%" }});
    });
  </script>
</Layout>
