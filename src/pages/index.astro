---
import Layout from '../layouts/Layout.astro';

const projetos = [
  {
    type: 'BOT . PYTHON',
    title: 'Bot Trader',
    description: '17 versoes de estrategias quantitativas. Deploy containerizado, paper trading 24/7 na Kraken.',
    tags: ['PYTHON', 'FREQTRADE', 'DOCKER', 'TA-LIB'],
    repo: 'https://github.com/caiom21/bot-trader'
  },
  {
    type: 'WEB . REACT',
    title: 'Ponto Cruz E-commerce',
    description: 'Loja de artesanatos e bordados com foco em performance e acessibilidade.',
    tags: ['REACT', 'NODE.JS', 'TAILWIND'],
    repo: 'https://github.com/caiom21/ponto-cruz-ecommerce'
  }
];

const stack = [
  'REACT', 'TYPESCRIPT', 'NODE.JS', 'NEXT.JS',
  'VUE.JS', 'PYTHON', 'DOCKER', 'FIGMA',
  'N8N', 'POSTGRESQL', 'TAILWIND', 'REACT NATIVE',
];

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/caiom21', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.36 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.36 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/caio-miranda-dev', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>' },
  { name: 'Instagram', href: 'https://www.instagram.com/caio.dev.pe/', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>' },
];
---

<Layout title="Caio Miranda | Full Stack Developer">

  <section class="relative w-full py-32 md:py-48">
    <div class="absolute inset-0 bg-grid z-0 pointer-events-none"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="flex flex-col md:flex-row gap-16 md:gap-24 items-center md:items-start">

        <div class="flex-1 max-w-2xl text-center md:text-left">
          <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest text-accent mb-8 uppercase hero-tag">
            <div class="w-8 h-[1px] bg-accent"></div>
            Full-Stack Developer
          </div>

          <h1 class="text-5xl md:text-8xl font-sans font-bold leading-[0.9] tracking-tight text-text hero-name">
            Caio<br/><span class="text-accent">Miranda</span>
          </h1>

          <p class="mt-6 text-sm font-mono text-text/60 leading-relaxed hero-desc">
            React &middot; Node.js &middot; TypeScript &middot; IA &amp; Automacao<br/>
            Bezerros, PE &mdash; disponivel para remoto
          </p>

          <div class="flex flex-wrap justify-center md:justify-start gap-3 mt-8 hero-actions">
            {socialLinks.map(social => (
              <a href={social.href} target="_blank" rel="noopener noreferrer"
                 class="w-10 h-10 flex items-center justify-center border border-text/20 text-text/50 hover:border-accent hover:text-accent transition-colors"
                 aria-label={social.name}
                 set:html={social.svg} />
            ))}
          </div>

          <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-10 hero-actions">
            <a href="#projetos" class="px-6 py-3 border border-accent text-accent hover:bg-accent hover:text-bg transition-colors font-mono text-sm uppercase">Ver Projetos</a>
            <a href="/contato" class="px-6 py-3 border border-text/20 text-text/80 hover:border-text hover:text-text transition-colors font-mono text-sm uppercase">Contato</a>
          </div>
        </div>

        <div class="flex-shrink-0">
          <div class="w-56 h-56 md:w-72 md:h-72 relative group border border-accent/20 hover:border-accent transition-colors overflow-hidden">
            <div class="card-corner hidden md:block z-20"></div>
            <img src="/fotoPerfil.jpg" alt="Caio Miranda" class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 z-10 relative" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="projetos" class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2">Projeto em destaque</h2>
        <p class="text-sm font-mono text-text/40">Trabalhos recentes e relevantes.</p>
      </div>
      <a href="/projetos" class="hidden md:block text-xs font-mono tracking-widest text-accent/60 hover:text-accent transition-colors">Ver todos &rarr;</a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {projetos.map(proj => (
        <div class="relative bg-surface border border-accent/20 p-8 group hover:border-accent transition-colors reveal">
          <div class="card-corner opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="text-[10px] font-mono tracking-widest text-text/40 mb-3 uppercase">{proj.type}</div>
          <h3 class="text-xl font-bold mb-3 text-text">{proj.title}</h3>
          <p class="text-sm font-mono text-text/60 mb-6">{proj.description}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {proj.tags.map(tag => (
              <span class="px-2 py-1 border border-accent/30 text-accent text-[10px] font-mono tracking-wider">{tag}</span>
            ))}
          </div>
          <a href={proj.repo} target="_blank" class="text-xs font-mono tracking-widest text-accent hover:underline underline-offset-4">
            CODIGO-FONTE &rarr;
          </a>
        </div>
      ))}
    </div>
    <div class="md:hidden mt-6 text-center">
      <a href="/projetos" class="text-xs font-mono tracking-widest text-accent/60 hover:text-accent transition-colors">Ver todos os projetos &rarr;</a>
    </div>
  </section>

  <section id="stack" class="container mx-auto px-4 py-24 border-b border-accent/20">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-xs font-mono tracking-widest text-accent uppercase mb-2">Stack Principal</h2>
        <p class="text-sm font-mono text-text/40">Ferramentas e linguagens do dia a dia.</p>
      </div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {stack.map(tech => (
        <div class="flex items-center justify-center px-4 py-4 border border-accent/20 bg-surface hover:border-accent hover:text-accent transition-all reveal group">
          <span class="text-xs font-mono tracking-wider text-text/60 group-hover:text-accent">{tech}</span>
        </div>
      ))}
    </div>
  </section>

  <footer class="container mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-left">
        <p class="text-xs font-mono text-text/40">&copy; 2026 Caio Miranda. Todos os direitos reservados.</p>
      </div>
      <div class="flex items-center gap-4">
        {socialLinks.map(social => (
          <a href={social.href} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 flex items-center justify-center text-text/30 hover:text-accent transition-colors"
             aria-label={social.name}
             set:html={social.svg} />
        ))}
      </div>
    </div>
  </footer>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener('astro:page-load', () => {
      gsap.registerPlugin(ScrollTrigger);

      // Hero entrance
      gsap.fromTo('.hero-name', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" });
      gsap.fromTo('.hero-tag, .hero-desc, .hero-actions',
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: "power2.out", delay: 0.3 }
      );

      // Reveal on scroll
      const elements = document.querySelectorAll('.reveal');
      elements.forEach((el) => {
        gsap.fromTo(el, { opacity: 0, y: 20 }, {
          scrollTrigger: {
            trigger: el,
            start: "top 95%",
          },
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power2.out",
          clearProps: "all"
        });
      });
    });
  </script>
</Layout>
