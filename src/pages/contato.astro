---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import Footer from '../components/Footer.astro';
import { socialLinks, contactInfo } from '../data/social';
---

<Layout title="Contato | Caio Miranda" description="Entre em contato com Caio Miranda — desenvolvedor full-stack disponível para oportunidades remotas.">

  <!-- Header -->
  <div class="relative w-full border-b border-border">
    <div class="absolute inset-0 bg-grid z-0 pointer-events-none"></div>
    <div class="max-w-[1100px] mx-auto px-6 relative z-10">
      <section class="py-16 md:py-24">
        <h1 class="text-4xl md:text-5xl font-display font-bold leading-tight tracking-tight mb-4 text-text">
          Sobre &amp; <span class="text-accent">Contato</span>
        </h1>
        <p class="text-sm font-mono text-text-secondary max-w-md leading-relaxed">
          Vamos construir algo incrível.
        </p>
      </section>
    </div>
  </div>

  <!-- Content -->
  <section class="max-w-[1100px] mx-auto px-6 py-24">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">

      <!-- Left: info -->
      <div class="reveal">
        <div class="text-[15px] font-sans text-text-secondary leading-relaxed space-y-6 mb-12">
          <p>Sou um Desenvolvedor Full Stack apaixonado por arquiteturas elegantes, otimização de performance e automação inteligente.</p>
          <p>Análise e solução de problemas através de código robusto, escalável e testes limpos.</p>
        </div>

        <div class="flex flex-col gap-6">
          <div class="border border-border bg-surface p-6 relative group hover:border-accent transition-colors">
            <div class="card-corner opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <h3 class="font-mono text-[11px] tracking-[0.15em] text-accent mb-6 uppercase">Informações</h3>
            <ul class="space-y-4 text-[12px] font-mono text-text-secondary">
              <li class="grid grid-cols-[100px_1fr]">
                <span class="text-text-muted">LOCAL</span>
                <span>{contactInfo.location}, Brasil</span>
              </li>
              <li class="grid grid-cols-[100px_1fr]">
                <span class="text-text-muted">EMAIL</span>
                <a href={`mailto:${contactInfo.email}`} class="text-accent hover:underline underline-offset-4">{contactInfo.email}</a>
              </li>
              <li class="grid grid-cols-[100px_1fr]">
                <span class="text-text-muted">GITHUB</span>
                <a href="https://github.com/caiom21" class="text-accent hover:underline underline-offset-4">/caiom21</a>
              </li>
              <li class="grid grid-cols-[100px_1fr]">
                <span class="text-text-muted">TELEFONE</span>
                <a href={contactInfo.whatsapp} class="text-accent hover:underline underline-offset-4">{contactInfo.phone}</a>
              </li>
            </ul>
          </div>

          <div class="flex gap-3">
            {socialLinks.map(social => (
              <a href={social.href} target="_blank" rel="noopener noreferrer"
                 class="w-10 h-10 flex items-center justify-center border border-border text-text-muted hover:border-accent hover:text-accent transition-all duration-150"
                 aria-label={social.name}
                 set:html={social.svg} />
            ))}
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal">
        <form class="flex flex-col gap-6 bg-surface p-8 border border-border relative group hover:border-accent transition-colors">
          <div class="card-corner opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <h2 class="font-mono text-[11px] tracking-[0.15em] text-accent mb-2 uppercase">Nova Mensagem</h2>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-mono tracking-[0.15em] text-text-muted uppercase">Nome</label>
            <input type="text" class="px-4 py-3 border border-border text-sm font-mono bg-transparent text-text focus:outline-none focus:border-accent transition-colors" required />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-mono tracking-[0.15em] text-text-muted uppercase">Email</label>
            <input type="email" class="px-4 py-3 border border-border text-sm font-mono bg-transparent text-text focus:outline-none focus:border-accent transition-colors" required />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-mono tracking-[0.15em] text-text-muted uppercase">Mensagem</label>
            <textarea rows="4" class="px-4 py-3 border border-border text-sm font-mono bg-transparent text-text focus:outline-none focus:border-accent transition-colors resize-none" required></textarea>
          </div>

          <button type="submit" class="mt-4 py-3 bg-accent text-bg text-[11px] font-mono tracking-[0.15em] uppercase hover:bg-accent-hover transition-colors cursor-pointer">
            Enviar Mensagem
          </button>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    document.addEventListener('astro:page-load', () => {
      gsap.registerPlugin(ScrollTrigger);

      const elements = document.querySelectorAll('.reveal');
      elements.forEach((el) => {
        gsap.fromTo(el, { opacity: 0, y: 20 }, {
          scrollTrigger: { trigger: el, start: "top 95%" },
          y: 0, opacity: 1, duration: 0.8, ease: "power2.out", clearProps: "all"
        });
      });
    });
  </script>
</Layout>
